{
  "$comment": "Design tokens for the Chebora email system. Mirrors/extends the constants already defined at the top of lib/email.js (see design/email-design-system.md for rationale). Meant to be the single source of truth once the MJML migration applies this system -- either import this file directly or keep it hand-in-sync with whatever constants file the MJML build uses.",
  "brand": {
    "name": "Chebora",
    "lockupSuffix": "Tracker",
    "wordmarkFont": "'Space Grotesk', 'Plus Jakarta Sans', Arial, sans-serif",
    "wordmarkWeight": 800,
    "wordmarkTracking": "-0.02em",
    "lockupSuffixWeight": 500
  },
  "font": {
    "body": "'Plus Jakarta Sans', Arial, sans-serif",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
  },
  "color": {
    "primary": "#0052cc",
    "bg": "#f8f9fb",
    "surface": "#ffffff",
    "text": "#1a1c1e",
    "textSecondary": "#44474e",
    "border": "#e6e7eb",
    "success": "#0a7a34",
    "danger": "#b03030",
    "info": { "bg": "#eef2ff", "text": "#0052cc" },
    "accent": { "bg": "#fef3e2", "text": "#b45309" },
    "airline": {
      "G3": "#ff5a00",
      "LA": "#e60050",
      "AR": "#00205b"
    }
  },
  "radius": {
    "card": "12px",
    "button": "8px",
    "pill": "999px"
  },
  "spacing": [4, 8, 12, 16, 24, 32],
  "type": {
    "wordmark": { "size": "22px", "weight": 800 },
    "wordmarkSuffix": { "size": "14px", "weight": 500 },
    "emailTitle": { "size": "20px", "weight": 700 },
    "sectionHeading": { "size": "24px", "weight": 700 },
    "cardRouteTitle": { "size": "18px", "weight": 700 },
    "price": { "size": "28px", "weight": 700 },
    "body": { "size": "14px", "weight": 400 },
    "microLabel": { "size": "12px", "weight": 600, "letterSpacing": "0.5px", "textTransform": "uppercase" },
    "chip": { "size": "13px", "weight": 600 }
  },
  "icons": {
    "allowed": ["inline-svg-only"],
    "emojiPolicy": "none",
    "existing": ["ICON_PLANE", "ICON_ROUTE", "ICON_GLOBE", "ICON_TROPHY", "ICON_TREND_DOWN"],
    "toAdd": ["ICON_TREND_UP"],
    "keepAsUnicode": ["↓", "↑", "↘", "↗"]
  }
}
